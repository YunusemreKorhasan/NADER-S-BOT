{
  "name": "cubecraft-discord-bot",
  "version": "1.0.0",
  "description": "Discord bot for CubeCraft Minecraft server statistics",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "postinstall": "npm run build"
  },
  "keywords": [
    "discord",
    "bot",
    "cubecraft",
    "minecraft",
    "statistics"
  ],
  "license": "MIT",
  "type": "module",
  "dependencies": {
